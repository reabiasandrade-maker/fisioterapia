    return historico.reduce((acc, item) => {
      acc[item.local] = (acc[item.local] || 0) + 1;
      return acc;
    }, {});
  }, [historico]);

  const visibleParts = bodyParts.filter((part) => part.side === side);

  return (
    <Card className="rounded-3xl border-0 shadow-md">
      <CardHeader className="flex flex-row items-center justify-between space-y-0">
        <div>
          <CardTitle className="text-lg">Mapa corporal</CardTitle>

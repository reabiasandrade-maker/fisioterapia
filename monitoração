                                <div className="flex flex-wrap items-center gap-2">
                                  <span className="text-sm font-semibold">{item.data}</span>
                                  <Badge className="rounded-full bg-slate-100 text-slate-700">{item.tipo}</Badge>
                                  <Badge className={cn("rounded-full border", severityClass(item.severidade))}>{item.severidade}</Badge>
                                </div>
                                <div className="mt-2 font-medium">{bodyParts.find((p) => p.id === item.local)?.label || item.local}</div>
                                <p className="mt-2 text-sm text-slate-600">{item.descricao}</p>
                                <div className="mt-3">
                                  <Badge className={cn("rounded-full border", statusClass(item.status))}>{item.status}</Badge>
                                </div>
                              </div>
                            </div>
                          ))
                        )}
                      </div>
                    </CardContent>
                  </Card>
                </TabsContent>
              </Tabs>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
